# ========== 飞书应用配置 ==========
# 从飞书开发者后台获取
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# 从飞书机器人配置页面的"事件订阅"中获取
FEISHU_VERIFY_TOKEN=your_verify_token_here
FEISHU_ENCRYPT_KEY=your_encrypt_key_here

# ========== Claude API配置 ==========
# 从 https://console.anthropic.com 获取
ANTHROPIC_API_KEY=your_claude_api_key_here

# ========== 服务器配置 ==========
PORT=3000
NODE_ENV=production
